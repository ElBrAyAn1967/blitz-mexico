---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('reportes');
const projects = allProjects.filter(p => p.data.slug !== 'summary');

const totalMessages = projects.reduce((s, p) => s + p.data.messages, 0);
const totalProjects = projects.length;
const totalErrors = projects.reduce((s, p) => s + p.data.errors.length, 0);
const resolvedErrors = projects.reduce((s, p) => s + p.data.errors.filter(e => e.resolved).length, 0);

// Estimate agent involvement per project based on message volume
// Higher message count = more agent interaction needed
const projectsByActivity = [...projects].sort((a, b) => b.data.messages - a.data.messages);
const highActivityProjects = projectsByActivity.filter(p => p.data.messages >= 100);
const medActivityProjects = projectsByActivity.filter(p => p.data.messages >= 30 && p.data.messages < 100);

// Agent definitions (semi-static since agent data isn't in MDs)
const agents = [
  {
    name: 'devrel-banana',
    displayName: 'Ana Banana',
    role: 'DevRel Frutero',
    style: 'Guia paso a paso, explica el "por que"',
    specialty: 'Onboarding, arquitectura, pitches, deploy',
    threads: totalProjects,
    estimatedMessages: Math.round(totalMessages * 0.65),
    activeHours: '~8h',
    firstAction: '15:43 UTC',
    lastAction: '~23:29 UTC',
    color: 'purple',
    // Banana helped all projects with onboarding
    projectsHelped: projects.map(p => p.data.title),
  },
  {
    name: 'aibus-dumbleclaw',
    displayName: 'PMO Ops',
    role: 'Frutero Club',
    style: 'Hace el trabajo directamente, entrega codigo',
    specialty: 'Debugging, construir UIs, prompts para agentes',
    threads: Math.min(5, highActivityProjects.length),
    estimatedMessages: Math.round(totalMessages * 0.25),
    activeHours: '~3h',
    firstAction: '~19:45 UTC',
    lastAction: '~22:35 UTC',
    color: 'blue',
    // Aibus focused on high-activity projects
    projectsHelped: highActivityProjects.slice(0, 5).map(p => p.data.title),
  },
];

const inactiveAgents = ['Fruterito', 'kukulcan', 'Scarfdrilo'];
---
<Layout title="Actividad de Agentes">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2 flex items-center gap-3">
      <svg class="w-8 h-8 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/></svg>
      Actividad de Agentes
    </h1>
    <p class="text-gray-400">Sabado 21 de Febrero 2026 — estimaciones basadas en {totalMessages} mensajes de {totalProjects} proyectos</p>
  </div>

  <!-- Overview -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    {[
      { label: "Mensajes totales", value: `${totalMessages}+`, iconSvg: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>' },
      { label: "Proyectos atendidos", value: totalProjects, iconSvg: '<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>' },
      { label: "Errores resueltos", value: `${resolvedErrors}/${totalErrors}`, iconSvg: '<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>' },
      { label: "Agentes activos", value: '2/5', iconSvg: '<rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/>' },
    ].map(s => (
      <div class="bg-purple-900/20 border border-purple-800/30 rounded-xl p-4 text-center">
        <div class="flex justify-center mb-2">
          <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={s.iconSvg} /></svg>
        </div>
        <div class="text-xl font-bold text-white">{s.value}</div>
        <div class="text-xs text-gray-400 mt-1">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Agent cards -->
  <div class="grid md:grid-cols-2 gap-6 mb-12">
    {agents.map(agent => (
      <div class="bg-purple-900/20 border border-purple-700/40 rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <svg class="w-8 h-8 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/></svg>
          <div>
            <h2 class="text-xl font-bold text-white">{agent.name}</h2>
            <p class="text-purple-400 text-sm">{agent.displayName} - {agent.role}</p>
          </div>
          <span class="ml-auto w-3 h-3 bg-green-400 rounded-full"></span>
        </div>
        <div class="grid grid-cols-3 gap-3 mb-4">
          {[
            { l: 'Threads', v: agent.threads },
            { l: 'Activo', v: agent.activeHours },
            { l: 'Mensajes est.', v: `${agent.estimatedMessages}+` },
          ].map(s => (
            <div class="text-center bg-purple-900/30 rounded-lg p-2">
              <div class="text-lg font-bold text-white">{s.v}</div>
              <div class="text-xs text-gray-400">{s.l}</div>
            </div>
          ))}
        </div>
        <div class="text-sm text-gray-300 space-y-1">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 text-yellow-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
            <span><strong>Especialidad:</strong> {agent.specialty}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Primera accion: {agent.firstAction}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Ultima accion: {agent.lastAction}</span>
          </div>
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 text-purple-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
            <span>Estilo: {agent.style}</span>
          </div>
        </div>

        <!-- Projects helped -->
        <div class="mt-4 pt-4 border-t border-purple-800/30">
          <div class="text-xs text-purple-400 font-semibold mb-2 flex items-center gap-1">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
            Proyectos atendidos ({agent.projectsHelped.length})
          </div>
          <div class="flex flex-wrap gap-1">
            {agent.projectsHelped.map(name => (
              <span class="text-xs bg-purple-900/30 text-purple-300 border border-purple-800/30 rounded px-2 py-0.5">{name}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Per-project agent activity estimate -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
      <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
      Actividad Estimada por Proyecto
    </h2>
    <div class="bg-[#0f0f1a] border border-purple-900/30 rounded-xl p-5">
      <div class="space-y-3">
        {projectsByActivity.map(p => {
          const intensity = p.data.messages >= 200 ? 'Alta' : p.data.messages >= 100 ? 'Media' : p.data.messages >= 30 ? 'Baja' : 'Minima';
          const intensityColor = p.data.messages >= 200 ? 'text-green-400' : p.data.messages >= 100 ? 'text-blue-400' : p.data.messages >= 30 ? 'text-yellow-400' : 'text-gray-500';
          return (
            <div class="flex items-center gap-3">
              <span class="text-sm text-gray-400 w-36 truncate">{p.data.title}</span>
              <div class="flex-1 h-3 bg-gray-800 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-purple-600 to-purple-400 rounded-full" style={`width:${Math.round((p.data.messages / Math.max(...projects.map(x => x.data.messages))) * 100)}%`}></div>
              </div>
              <span class="text-sm font-mono text-purple-300 w-12 text-right">{p.data.messages}</span>
              <span class={`text-xs w-14 text-right ${intensityColor}`}>{intensity}</span>
            </div>
          );
        })}
      </div>
      <div class="mt-4 pt-4 border-t border-gray-800/50 text-xs text-gray-500">
        Mas mensajes = mayor interaccion con agentes (onboarding, debug, arquitectura)
      </div>
    </div>
  </section>

  <!-- Inactive agents -->
  <section>
    <h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
      <svg class="w-6 h-6 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 15h0"/><path d="M16 15h0"/></svg>
      Agentes sin actividad en el Blitz
    </h2>
    <div class="grid md:grid-cols-3 gap-4">
      {inactiveAgents.map(a => (
        <div class="bg-gray-900/30 border border-gray-800/30 rounded-xl p-4 opacity-60">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-gray-600"></span>
            <span class="font-medium text-gray-400">{a}</span>
          </div>
          <p class="text-xs text-gray-600 mt-2">Sin mensajes detectados en los threads del blitz. Pueden haber estado activos en otros canales no analizados.</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
