---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('reportes');
  return projects
    .filter(p => p.data.slug !== 'summary')
    .map(p => ({
      params: { slug: p.data.slug },
      props: { entry: p },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const statusColors: Record<string, string> = {
  'completed': 'bg-green-900/40 text-green-400 border-green-700/40',
  'in-progress': 'bg-blue-900/40 text-blue-400 border-blue-700/40',
  'concept': 'bg-yellow-900/40 text-yellow-400 border-yellow-700/40',
  'minimal': 'bg-gray-800/40 text-gray-400 border-gray-700/40',
};
const statusLabels: Record<string, string> = {
  'completed': 'Completado', 'in-progress': 'En progreso', 'concept': 'Concepto', 'minimal': 'Minimal',
};

const severityColors: Record<string, string> = {
  'critical': 'bg-red-900/50 text-red-400 border-red-800/50',
  'high': 'bg-red-900/50 text-red-400 border-red-800/50',
  'medium': 'bg-yellow-900/40 text-yellow-400 border-yellow-800/40',
  'low': 'bg-green-900/40 text-green-400 border-green-800/40',
};
---
<Layout title={d.title}>
  <!-- Back link -->
  <a href="/proyectos" class="inline-flex items-center gap-1 text-sm text-purple-400 hover:text-purple-300 mb-6 group">
    <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    Volver a Proyectos
  </a>

  <!-- Header -->
  <div class="bg-purple-900/20 border border-purple-700/40 rounded-2xl p-6 mb-8">
    <div class="flex items-start justify-between flex-wrap gap-4">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">{d.title}</h1>
        <div class="flex items-center gap-3 flex-wrap">
          <span class="text-sm text-purple-300">{d.area}</span>
          <span class={`text-xs border rounded-full px-2 py-0.5 ${statusColors[d.status]}`}>{statusLabels[d.status]}</span>
        </div>
      </div>
      <div class="text-right">
        <div class="text-2xl font-bold text-white">{d.phase}%</div>
        <div class="text-xs text-gray-400">avance</div>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="mt-4 h-2 bg-gray-800 rounded-full overflow-hidden">
      <div class="h-full bg-gradient-to-r from-purple-600 to-purple-400 rounded-full" style={`width:${Math.min(d.phase, 100)}%`}></div>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
      {[
        { label: 'Miembros', value: d.members, iconSvg: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>' },
        { label: 'Mensajes', value: d.messages, iconSvg: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>' },
        { label: 'Contratos', value: d.contracts.length, iconSvg: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>' },
        { label: 'Errores', value: d.errors.length, iconSvg: '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>' },
      ].map(s => (
        <div class="bg-purple-900/30 rounded-lg p-3 text-center">
          <div class="flex justify-center mb-1">
            <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={s.iconSvg} /></svg>
          </div>
          <div class="text-lg font-bold text-white">{s.value}</div>
          <div class="text-xs text-gray-400">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="grid md:grid-cols-3 gap-8">
    <!-- Main content -->
    <div class="md:col-span-2">
      <div class="prose prose-invert prose-purple max-w-none
        prose-headings:text-white prose-p:text-gray-300 prose-li:text-gray-300
        prose-a:text-purple-400 prose-strong:text-white prose-code:text-purple-300
        prose-hr:border-purple-900/30">
        <Content />
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Team -->
      {d.team.length > 0 && (
        <div class="bg-[#0f0f1a] border border-purple-900/30 rounded-xl p-5">
          <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Equipo
          </h3>
          <div class="space-y-2">
            {d.team.map(m => (
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-purple-400 rounded-full"></span>
                <span class="text-sm text-white">{m.name}</span>
                {m.discord && <span class="text-xs text-gray-500">@{m.discord}</span>}
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Tech Stack -->
      {d.techStack.length > 0 && (
        <div class="bg-[#0f0f1a] border border-purple-900/30 rounded-xl p-5">
          <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            Tech Stack
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {d.techStack.map(t => (
              <span class="text-xs bg-purple-900/30 text-purple-300 border border-purple-800/30 rounded px-2 py-0.5">{t}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Contracts -->
      {d.contracts.length > 0 && (
        <div class="bg-[#0f0f1a] border border-purple-900/30 rounded-xl p-5">
          <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Contratos
          </h3>
          <div class="space-y-3">
            {d.contracts.map(c => (
              <div class="text-sm">
                <div class="flex items-center gap-2">
                  {c.deployed ? (
                    <svg class="w-4 h-4 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  ) : (
                    <svg class="w-4 h-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                  )}
                  <span class={c.deployed ? 'text-green-400 font-medium' : 'text-gray-400'}>{c.name}</span>
                </div>
                {c.address && (
                  <div class="ml-6 mt-1 font-mono text-xs text-gray-500 break-all">{c.address}</div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Errors -->
      {d.errors.length > 0 && (
        <div class="bg-[#0f0f1a] border border-purple-900/30 rounded-xl p-5">
          <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            Errores ({d.errors.length})
          </h3>
          <div class="space-y-3">
            {d.errors.map(e => (
              <div class="border-l-2 border-gray-700 pl-3">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-xs font-bold px-1.5 py-0.5 rounded border ${severityColors[e.severity]}`}>{e.severity.toUpperCase()}</span>
                  {e.resolved && (
                    <svg class="w-3 h-3 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  )}
                </div>
                <div class="text-sm text-white">{e.description}</div>
                <div class="text-xs text-gray-500 mt-0.5">{e.cause}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Links -->
      <div class="bg-[#0f0f1a] border border-purple-900/30 rounded-xl p-5">
        <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          Enlaces
        </h3>
        <div class="space-y-2">
          {d.repo && (
            <a href={d.repo} target="_blank" class="flex items-center gap-2 text-sm text-purple-400 hover:text-purple-300">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              GitHub Repository
            </a>
          )}
          {d.deployUrl && (
            <a href={d.deployUrl} target="_blank" class="flex items-center gap-2 text-sm text-green-400 hover:text-green-300">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
              Live Deploy
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>
