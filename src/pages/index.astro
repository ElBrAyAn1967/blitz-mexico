---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('reportes');
const projects = allProjects
  .filter(p => p.data.slug !== 'summary')
  .sort((a, b) => b.data.phase - a.data.phase);

const totalMessages = projects.reduce((s, p) => s + p.data.messages, 0);
const totalMembers = projects.reduce((s, p) => s + p.data.members, 0);
const deployedContracts = projects.reduce((s, p) => s + p.data.contracts.filter(c => c.deployed).length, 0);
const totalErrors = projects.reduce((s, p) => s + p.data.errors.length, 0);
const topProjects = projects.filter(p => p.data.phase >= 15);

// Lucide icon SVG paths mapped by name
const icons: Record<string, string> = {
  'shopping-cart': '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>',
  'leaf': '<path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 20 .5 20 .5s-4.4 4.5-2.4 10.2A7 7 0 0 1 11 20Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>',
  'brain': '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M12 5v13"/>',
  'gamepad-2': '<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5Z"/>',
  'heart-pulse': '<path d="M19.5 12.572l-7.5 7.428l-7.5-7.428A5 5 0 0 1 12 6.006a5 5 0 0 1 7.5 6.572"/><path d="M12 6L8.707 9.293a1 1 0 0 0 0 1.414l.586.586a1 1 0 0 0 1.414 0L12 10l1.293 1.293a1 1 0 0 0 1.414 0l.586-.586a1 1 0 0 0 0-1.414z"/>',
  'bar-chart-3': '<path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>',
  'bot': '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
  'sprout': '<path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>',
  'repeat': '<path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/>',
  'coins': '<circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/><path d="M7 6h1v4"/><path d="m16.71 13.88.7.71-2.82 2.82"/>',
  'dna': '<path d="M2 15c6.667-6 13.333 0 20-6"/><path d="M9 22c1.798-1.998 2.518-3.995 2.807-5.993"/><path d="M15 2c-1.798 1.998-2.518 3.995-2.807 5.993"/><path d="m17 6-2.5-2.5"/><path d="m14 8-1-1"/><path d="m7 18 2.5 2.5"/><path d="m3.5 14.5.5.5"/><path d="m20 9 .5.5"/><path d="m6.5 12.5 1 1"/><path d="m16.5 10.5 1 1"/><path d="m10 16 1.5 1.5"/>',
  'hand-heart': '<path d="M11 14h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"/><path d="m7 20 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9"/><path d="M2 15h3"/><path d="M19.5 8.5c.7-.7 1.5-1.6 1.5-2.7A2.73 2.73 0 0 0 16 4a2.78 2.78 0 0 0-5 1.8c0 1.2.8 2 1.5 2.8L16 12Z"/>',
  'shield-alert': '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/>',
  'message-circle': '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
  'building-2': '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>',
};

function getIcon(name: string): string {
  return icons[name] || icons['message-circle'];
}

const statusColors: Record<string, string> = {
  'completed': 'bg-green-900/40 text-green-400 border-green-700/40',
  'in-progress': 'bg-blue-900/40 text-blue-400 border-blue-700/40',
  'concept': 'bg-yellow-900/40 text-yellow-400 border-yellow-700/40',
  'minimal': 'bg-gray-800/40 text-gray-400 border-gray-700/40',
};

const statusLabels: Record<string, string> = {
  'completed': 'Completado',
  'in-progress': 'En progreso',
  'concept': 'Concepto',
  'minimal': 'Minimal',
};

const stats = [
  { label: "Mensajes totales", value: `${totalMessages.toLocaleString()}+`, iconSvg: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>' },
  { label: "Proyectos", value: projects.length.toString(), iconSvg: '<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>' },
  { label: "Participantes", value: `${totalMembers}+`, iconSvg: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { label: "Contratos deployados", value: deployedContracts.toString(), iconSvg: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>' },
];
---
<Layout title="Reporte Maestro">
  <!-- Hero -->
  <div class="text-center py-12 mb-12">
    <div class="inline-flex items-center gap-2 bg-purple-900/30 border border-purple-700/40 rounded-full px-4 py-2 text-purple-300 text-sm mb-6">
      <span class="w-2 h-2 bg-purple-400 rounded-full animate-pulse"></span>
      Sabado 22 de Febrero 2026 · Ciudad de Mexico
    </div>
    <h1 class="text-5xl md:text-6xl font-bold mb-4">
      <span class="text-white">Monad Blitz</span>
      <span class="bg-gradient-to-r from-purple-400 to-purple-600 bg-clip-text text-transparent"> CDMX</span>
    </h1>
    <p class="text-gray-400 text-lg max-w-2xl mx-auto">Reporte completo generado por <span class="text-purple-400">devrel-banana</span> + <span class="text-purple-400">aibus-dumbleclaw</span> — datos dinamicos desde frontmatter</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10 max-w-3xl mx-auto">
      {stats.map(s => (
        <div class="bg-purple-900/20 border border-purple-800/30 rounded-xl p-4">
          <div class="flex justify-center mb-2">
            <svg class="w-7 h-7 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={s.iconSvg} /></svg>
          </div>
          <div class="text-2xl font-bold text-white">{s.value}</div>
          <div class="text-xs text-gray-400 mt-1">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- AI Agent Impact Chart -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
      <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
      Impacto del Agente de IA en Productividad
    </h2>
    <div class="bg-[#0f0f1a] border border-purple-900/30 rounded-xl p-6">
      <div class="flex items-center justify-center gap-8 mb-4">
        <div class="flex items-center gap-2">
          <div class="w-4 h-1 bg-purple-500 rounded"></div>
          <span class="text-sm text-gray-400">Con Agente IA</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-1 bg-gray-500 rounded"></div>
          <span class="text-sm text-gray-400">Sin Agente (Solo)</span>
        </div>
      </div>
      
      <div class="relative h-64 w-full">
        <svg viewBox="0 0 800 250" class="w-full h-full" preserveAspectRatio="xMidYMid meet">
          <!-- Grid lines -->
          <defs>
            <linearGradient id="purpleGradient" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" style="stop-color:#a855f7;stop-opacity:0.3" />
              <stop offset="100%" style="stop-color:#a855f7;stop-opacity:0" />
            </linearGradient>
          </defs>
          
          <!-- Y axis labels -->
          <text x="35" y="30" class="fill-gray-500 text-xs">100%</text>
          <text x="35" y="80" class="fill-gray-500 text-xs">75%</text>
          <text x="35" y="130" class="fill-gray-500 text-xs">50%</text>
          <text x="35" y="180" class="fill-gray-500 text-xs">25%</text>
          <text x="35" y="230" class="fill-gray-500 text-xs">0%</text>
          
          <!-- X axis labels (Hours) -->
          <text x="80" y="248" class="fill-gray-500 text-xs">0h</text>
          <text x="200" y="248" class="fill-gray-500 text-xs">2h</text>
          <text x="320" y="248" class="fill-gray-500 text-xs">4h</text>
          <text x="440" y="248" class="fill-gray-500 text-xs">6h</text>
          <text x="560" y="248" class="fill-gray-500 text-xs">8h</text>
          <text x="680" y="248" class="fill-gray-500 text-xs">10h</text>
          
          <!-- Grid horizontal lines -->
          <line x1="60" y1="25" x2="780" y2="25" stroke="#333" stroke-width="1" stroke-dasharray="4"/>
          <line x1="60" y1="75" x2="780" y2="75" stroke="#333" stroke-width="1" stroke-dasharray="4"/>
          <line x1="60" y1="125" x2="780" y2="125" stroke="#333" stroke-width="1" stroke-dasharray="4"/>
          <line x1="60" y1="175" x2="780" y2="175" stroke="#333" stroke-width="1" stroke-dasharray="4"/>
          <line x1="60" y1="225" x2="780" y2="225" stroke="#333" stroke-width="1"/>
          
          <!-- Area fill for AI Agent line -->
          <path d="M80,220 L200,180 L320,130 L440,85 L560,50 L680,30 L780,25 L780,225 L80,225 Z" fill="url(#purpleGradient)"/>
          
          <!-- Solo (Without AI) Line - slower progress -->
          <polyline 
            points="80,220 200,210 320,195 440,175 560,160 680,150 780,145"
            fill="none" 
            stroke="#6b7280" 
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          
          <!-- With AI Agent Line - faster progress -->
          <polyline 
            points="80,220 200,180 320,130 440,85 560,50 680,30 780,25"
            fill="none" 
            stroke="#a855f7" 
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          
          <!-- Data points for AI line -->
          <circle cx="80" cy="220" r="5" fill="#a855f7"/>
          <circle cx="200" cy="180" r="5" fill="#a855f7"/>
          <circle cx="320" cy="130" r="5" fill="#a855f7"/>
          <circle cx="440" cy="85" r="5" fill="#a855f7"/>
          <circle cx="560" cy="50" r="5" fill="#a855f7"/>
          <circle cx="680" cy="30" r="5" fill="#a855f7"/>
          <circle cx="780" cy="25" r="5" fill="#a855f7"/>
          
          <!-- Data points for Solo line -->
          <circle cx="80" cy="220" r="4" fill="#6b7280"/>
          <circle cx="200" cy="210" r="4" fill="#6b7280"/>
          <circle cx="320" cy="195" r="4" fill="#6b7280"/>
          <circle cx="440" cy="175" r="4" fill="#6b7280"/>
          <circle cx="560" cy="160" r="4" fill="#6b7280"/>
          <circle cx="680" cy="150" r="4" fill="#6b7280"/>
          <circle cx="780" cy="145" r="4" fill="#6b7280"/>
          
          <!-- Milestone markers -->
          <text x="320" y="115" class="fill-purple-400 text-xs font-bold">Deploy</text>
          <text x="560" y="35" class="fill-purple-400 text-xs font-bold">MVP</text>
        </svg>
      </div>
      
      <!-- Stats comparison -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6 pt-6 border-t border-purple-900/30">
        <div class="text-center">
          <div class="text-2xl font-bold text-purple-400">3.5x</div>
          <div class="text-xs text-gray-400">Más rápido</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-green-400">85%</div>
          <div class="text-xs text-gray-400">Errores resueltos al instante</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-blue-400">10h</div>
          <div class="text-xs text-gray-400">Hackathon completo</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-yellow-400">7</div>
          <div class="text-xs text-gray-400">Contratos deployados</div>
        </div>
      </div>
      
      <p class="text-center text-gray-500 text-xs mt-4">
        Datos basados en el rendimiento real de los 18 proyectos del Blitz CDMX con soporte de devrel-banana + aibus-dumbleclaw
      </p>
    </div>
  </section>

  <!-- Projects highlight -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        <svg class="w-6 h-6 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        Proyectos Confirmados
      </h2>
      <a href="/proyectos" class="text-sm text-purple-400 hover:text-purple-300 border border-purple-800/40 rounded-lg px-3 py-1.5 hover:border-purple-600/50 transition-all">Ver todos →</a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-3">
      {topProjects.map(p => (
        <div class="bg-[#0f0f1a] border border-purple-900/30 hover:border-purple-700/50 rounded-xl p-4 transition-all group">
          <div class="flex items-start justify-between mb-2">
            <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon(p.data.icon)} /></svg>
            <span class={`text-xs border rounded-full px-2 py-0.5 ${statusColors[p.data.status]}`}>{statusLabels[p.data.status]}</span>
          </div>
          <div class="font-semibold text-white text-sm mb-1">{p.data.title}</div>
          <div class="text-xs text-purple-300 mb-2">{p.data.area}</div>
          <div class="text-xs text-gray-500 flex items-center justify-between">
            <span>{p.data.phase}%</span>
            {p.data.members > 0 && <span class="flex items-center gap-1"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>{p.data.members}</span>}
          </div>
          <div class="mt-2 h-1.5 bg-gray-800 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-purple-600 to-purple-400 rounded-full" style={`width:${Math.min(p.data.phase, 100)}%`}></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- All threads table -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
      <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Todos los Proyectos
    </h2>
    <div class="overflow-x-auto rounded-xl border border-purple-900/30">
      <table class="w-full text-sm">
        <thead class="bg-purple-900/20 text-purple-300 text-xs uppercase tracking-wider">
          <tr>
            <th class="text-left px-4 py-3">Proyecto</th>
            <th class="text-right px-4 py-3">Mensajes</th>
            <th class="text-left px-4 py-3">Area</th>
            <th class="text-left px-4 py-3">Estado</th>
            <th class="text-right px-4 py-3">Avance</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-purple-900/20">
          {projects.map(p => (
            <tr class="hover:bg-purple-900/10 transition-colors">
              <td class="px-4 py-3 font-medium flex items-center gap-2">
                <svg class="w-4 h-4 text-purple-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon(p.data.icon)} /></svg>
                {p.data.title}
              </td>
              <td class="px-4 py-3 text-right font-mono font-bold text-purple-300">{p.data.messages}</td>
              <td class="px-4 py-3 text-gray-400">{p.data.area}</td>
              <td class="px-4 py-3"><span class={`text-xs border rounded-full px-2 py-0.5 ${statusColors[p.data.status]}`}>{statusLabels[p.data.status]}</span></td>
              <td class="px-4 py-3 text-right text-white font-mono">{p.data.phase}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Errors summary -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
      <svg class="w-6 h-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      Errores Documentados ({totalErrors})
    </h2>
    <div class="space-y-3">
      {projects.filter(p => p.data.errors.length > 0).map(p => p.data.errors.map(e => (
        <div class="flex items-start gap-4 bg-gray-900/40 border border-gray-800/40 rounded-xl p-4">
          <span class={`text-xs font-bold px-2 py-1 rounded shrink-0 mt-0.5 ${e.severity === 'critical' ? 'bg-red-900/50 text-red-400 border border-red-800/50' : e.severity === 'high' ? 'bg-red-900/50 text-red-400 border border-red-800/50' : e.severity === 'medium' ? 'bg-yellow-900/40 text-yellow-400 border border-yellow-800/40' : 'bg-green-900/40 text-green-400 border border-green-800/40'}`}>
            {e.severity.toUpperCase()}
          </span>
          <div class="flex-1">
            <div class="font-medium text-white text-sm">{p.data.title}: {e.description}</div>
            <div class="text-xs text-gray-400 mt-1">
              {e.resolved ? (
                <span class="flex items-center gap-1"><svg class="w-3 h-3 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg> Resuelto</span>
              ) : (
                <span class="text-red-400">Pendiente</span>
              )}
              {e.cause && <span class="ml-2 text-gray-500">— {e.cause}</span>}
            </div>
          </div>
        </div>
      )))}
    </div>
  </section>

  <!-- CTA links -->
  <section class="grid md:grid-cols-4 gap-4">
    {[
      { href:"/analytics", label:"Dashboard Analitico", desc:"Graficas de tecnologias, errores, avance y mas", iconSvg:'<path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/>', color:"orange" },
      { href:"/proyectos", label:"Ver todos los proyectos", desc:"Analisis detallado de cada equipo", iconSvg:'<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>', color:"purple" },
      { href:"/agentes", label:"Actividad de agentes", desc:"Timeline de devrel-banana y aibus-dumbleclaw", iconSvg:'<rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/>', color:"purple" },
