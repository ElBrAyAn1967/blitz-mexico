---
<Layout title="Proyectos">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">🛠️ Proyectos del Blitz</h1>
    <p class="text-gray-400">Datos combinados: recolección manual en piso 🎯 + análisis de Discord 🤖</p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    {[
      { label: "Proyectos totales", value: "13+", icon: "🛠️" },
      { label: "Devs participantes", value: "35+", icon: "👩‍💻" },
      { label: "Contratos on-chain", value: "3+", icon: "⛓️" },
      { label: "% más alto", value: "38.12%", icon: "🏆" },
    ].map(s => (
      <div class="bg-purple-900/20 border border-purple-800/30 rounded-xl p-4 text-center">
        <div class="text-2xl mb-1">{s.icon}</div>
        <div class="text-xl font-bold text-white">{s.value}</div>
        <div class="text-xs text-gray-400 mt-1">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Legend -->
  <div class="flex gap-3 mb-6 flex-wrap text-xs">
    <span class="flex items-center gap-1.5 bg-green-900/20 border border-green-800/30 text-green-400 px-3 py-1.5 rounded-full">🎯 Datos manuales (alta prioridad)</span>
    <span class="flex items-center gap-1.5 bg-purple-900/20 border border-purple-800/30 text-purple-400 px-3 py-1.5 rounded-full">🤖 Datos de Discord</span>
    <span class="flex items-center gap-1.5 bg-blue-900/20 border border-blue-800/30 text-blue-400 px-3 py-1.5 rounded-full">✅ Ambas fuentes</span>
  </div>

  <!-- Projects grid -->
  <div class="space-y-4">
    {groundTruth.map((p) => (
      <div class={`rounded-2xl border p-5 transition-all ${p.potential === 5 ? 'bg-purple-900/20 border-purple-600/50 ring-1 ring-purple-500/20' : 'bg-[#0f0f1a] border-purple-900/30'}`}>
        <div class="flex items-start justify-between gap-4 mb-3 flex-wrap">
          <div class="flex items-center gap-3 flex-wrap">
            <span class="text-2xl">{p.emoji}</span>
            <div>
              <h2 class="text-lg font-bold text-white">{p.name}</h2>
              <span class="text-xs text-purple-300">{p.type}</span>
            </div>
            {p.badge && (
              <span class={`text-xs border rounded-full px-2 py-0.5 ${p.badgeColor === 'yellow' ? 'bg-yellow-900/30 text-yellow-400 border-yellow-700/40' : p.badgeColor === 'purple' ? 'bg-purple-900/30 text-purple-300 border-purple-700/40' : p.badgeColor === 'green' ? 'bg-green-900/30 text-green-400 border-green-700/40' : p.badgeColor === 'emerald' ? 'bg-emerald-900/30 text-emerald-400 border-emerald-700/40' : p.badgeColor === 'blue' ? 'bg-blue-900/30 text-blue-400 border-blue-700/40' : 'bg-gray-800 text-gray-400 border-gray-700/40'}`}>
                {p.badge}
              </span>
            )}
            <!-- Source badge -->
            <span class={`text-xs border rounded-full px-2 py-0.5 ${p.source === 'manual' ? 'bg-green-900/20 text-green-400 border-green-800/30' : p.source === 'both' ? 'bg-blue-900/20 text-blue-400 border-blue-800/30' : 'bg-purple-900/20 text-purple-400 border-purple-800/30'}`}>
              {p.source === 'manual' ? '🎯 Manual' : p.source === 'both' ? '✅ Verificado' : '🤖 Discord'}
            </span>
          </div>
          <div class="text-right">
            <div class="text-yellow-400">{"⭐".repeat(p.potential)}{"☆".repeat(5 - p.potential)}</div>
            {p.members && <div class="text-xs text-gray-400 mt-1">{p.members} miembro{p.members !== 1 ? 's' : ''}</div>}
          </div>
        </div>

        <!-- Building -->
        <p class="text-sm text-gray-300 bg-black/30 rounded-lg p-3 mb-3">{p.building}</p>

        <div class="flex flex-wrap gap-4 items-start">
          <!-- Phase bar -->
          <div class="flex-1 min-w-40">
            <div class="flex justify-between text-xs text-gray-400 mb-1">
              <span>Avance</span>
              <span class="text-white">{p.phaseLabel}</span>
            </div>
            {p.phase !== null && (
              <div class="h-2 bg-gray-800 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-purple-600 to-purple-400 rounded-full" style={`width:${Math.min(p.phase, 100)}%`}></div>
              </div>
            )}
          </div>

          <!-- Contracts -->
          {p.contracts && p.contracts.length > 0 && (
            <div class="flex-1 min-w-40">
              <div class="text-xs text-gray-400 mb-1">Contratos on-chain</div>
              {p.contracts.map(c => (
                <div class="text-xs">
                  <span class="text-green-400 font-medium">{c.name}</span>
                  {c.link ? (
                    <a href={c.link} target="_blank" class="block font-mono text-gray-500 hover:text-purple-400 truncate">{c.addr.slice(0,22)}…</a>
                  ) : (
                    <span class="block text-gray-500">{c.addr}</span>
                  )}
                </div>
              ))}
            </div>
          )}

          <!-- Repo -->
          {p.repo && (
            <div>
              <a href={p.repo} target="_blank" class="text-xs text-purple-400 hover:text-purple-300 hover:underline">📦 GitHub repo →</a>
            </div>
          )}
        </div>

        {p.notes && (
          <p class="text-xs text-gray-500 mt-3 border-t border-gray-800/50 pt-2 italic">{p.notes}</p>
        )}
      </div>
    ))}
  </div>
</Layout>
