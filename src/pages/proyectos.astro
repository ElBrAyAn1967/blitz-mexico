---
<Layout title="Proyectos">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">🛠️ Proyectos del Blitz</h1>
    <p class="text-gray-400">Análisis detallado de cada equipo — stack, errores, curva de aprendizaje y estado final</p>
  </div>

  <!-- Filter summary -->
  <div class="flex flex-wrap gap-3 mb-8">
    {["🔥 Todos", "✅ Deployados", "⭐⭐⭐⭐⭐ Top potencial"].map(f => (
      <span class="bg-purple-900/20 border border-purple-800/40 text-purple-300 text-sm px-3 py-1.5 rounded-full">{f}</span>
    ))}
  </div>

  <div class="space-y-6">
    {projects.map(p => (
      <div class={`rounded-2xl border p-6 ${p.highlight ? 'bg-purple-900/20 border-purple-600/50 ring-1 ring-purple-500/20' : p.archived ? 'bg-gray-900/30 border-gray-800/30 opacity-80' : 'bg-[#0f0f1a] border-purple-900/30'} transition-all`}>
        <!-- Header -->
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <div class="flex items-center gap-3 mb-1 flex-wrap">
              <h2 class="text-xl font-bold text-white">{p.emoji} {p.name}</h2>
              {p.highlight && <span class="text-xs bg-purple-600/40 text-purple-300 border border-purple-500/40 rounded-full px-2 py-0.5">🏆 Más completo</span>}
              {p.archived && <span class="text-xs bg-gray-700/40 text-gray-400 border border-gray-600/40 rounded-full px-2 py-0.5">Archivado</span>}
              {p.fundraise && <span class="text-xs bg-green-900/40 text-green-400 border border-green-700/40 rounded-full px-2 py-0.5">💰 {p.fundraise}</span>}
            </div>
            <p class="text-purple-300 text-sm italic">"{p.tagline}"</p>
          </div>
          <div class="text-right shrink-0">
            {p.msgs && <div class="text-2xl font-bold text-white">{p.msgs}</div>}
            {p.msgs && <div class="text-xs text-gray-400">mensajes</div>}
            <div class="flex items-center gap-1 mt-1 justify-end flex-wrap">
              {"⭐".repeat(p.potential)}{"☆".repeat(5 - p.potential)}
            </div>
          </div>
        </div>

        <!-- Concept -->
        <div class="bg-black/30 rounded-lg p-3 mb-4 text-sm text-gray-300">
          {p.concept}
          {p.taglineQuote && <p class="mt-2 text-purple-300 italic">"{p.taglineQuote}"</p>}
          {p.flow && <p class="mt-2 text-emerald-400 font-mono text-xs">{p.flow}</p>}
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          <!-- Stack -->
          <div>
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Stack</h3>
            <div class="flex flex-wrap gap-1.5">
              {p.stack.map(s => (
                <span class="text-xs bg-[#1a1a2e] border border-purple-900/40 text-purple-200 rounded px-2 py-0.5">{s}</span>
              ))}
            </div>
          </div>

          <!-- Contracts -->
          <div>
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Contratos on-chain</h3>
            {p.contracts.length > 0 ? (
              <div class="space-y-1">
                {p.contracts.map(c => (
                  <div>
                    <div class="text-xs text-green-400 font-medium">{c.name}</div>
                    {c.link ? (
                      <a href={c.link} target="_blank" class="text-xs font-mono text-gray-500 hover:text-purple-400 transition-colors break-all">{c.addr.slice(0,20)}…</a>
                    ) : (
                      <div class="text-xs font-mono text-gray-500 break-all">{c.addr}</div>
                    )}
                  </div>
                ))}
              </div>
            ) : (
              <span class="text-xs text-gray-600">No confirmados</span>
            )}
          </div>

          <!-- Info -->
          <div>
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Info</h3>
            <div class="space-y-1 text-xs text-gray-400">
              <div>👤 <span class="text-gray-300">{p.owner}</span></div>
              <div>⏰ <span class="text-gray-300">{p.startTime}</span></div>
              <div>📊 Nivel: <span class={`font-medium ${p.levelColor === 'purple' ? 'text-purple-400' : p.levelColor === 'red' ? 'text-red-400' : p.levelColor === 'yellow' ? 'text-yellow-400' : 'text-emerald-400'}`}>{p.level}</span></div>
              <div>🤖 {p.agents.join(", ")}</div>
              {p.repo && <div>📦 <a href={p.repo} target="_blank" class="text-purple-400 hover:underline">GitHub repo</a></div>}
              {p.deployUrl && <div>🚀 <a href={p.deployUrl} target="_blank" class="text-green-400 hover:underline">Ver deploy</a></div>}
            </div>
          </div>
        </div>

        <!-- Bugs -->
        {p.bugs.length > 0 && (
          <div class="mt-4">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">🐛 Errores detectados</h3>
            <div class="space-y-1.5">
              {p.bugs.map(b => (
                <div class="flex items-start gap-2 text-xs">
                  <span class={`shrink-0 px-1.5 py-0.5 rounded font-bold ${b.sev === 'HIGH' ? 'bg-red-900/40 text-red-400' : b.sev === 'MED' ? 'bg-yellow-900/30 text-yellow-500' : 'bg-gray-800 text-gray-500'}`}>{b.sev}</span>
                  <span class="text-gray-400">{b.error}</span>
                  <span class="text-gray-600">→</span>
                  <span class="text-green-400">{b.sol}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Learning + Status -->
        <div class="grid md:grid-cols-2 gap-4 mt-4">
          <div>
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">📈 Curva de aprendizaje</h3>
            <p class="text-xs text-gray-400">{p.learning}</p>
          </div>
          <div>
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">✅ Estado final</h3>
            <ul class="space-y-0.5">
              {p.finalStatus.map(s => (
                <li class="text-xs text-gray-400">{s}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</Layout>
