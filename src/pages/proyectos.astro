---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('reportes');
const projects = allProjects
  .filter(p => !['summary'].includes(p.data.slug))
  .sort((a, b) => b.data.phase - a.data.phase);

const totalProjects = projects.length;
const totalMembers = projects.reduce((s, p) => s + p.data.members, 0);
const deployedContracts = projects.reduce((s, p) => s + p.data.contracts.filter(c => c.deployed).length, 0);
const maxPhase = Math.max(...projects.map(p => p.data.phase));

const icons: Record<string, string> = {
  'shopping-cart': '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>',
  'leaf': '<path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 20 .5 20 .5s-4.4 4.5-2.4 10.2A7 7 0 0 1 11 20Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>',
  'brain': '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M12 5v13"/>',
  'gamepad-2': '<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5Z"/>',
  'heart-pulse': '<path d="M19.5 12.572l-7.5 7.428l-7.5-7.428A5 5 0 0 1 12 6.006a5 5 0 0 1 7.5 6.572"/>',
  'bar-chart-3': '<path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>',
  'bot': '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
  'sprout': '<path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/>',
  'repeat': '<path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/>',
  'coins': '<circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/>',
  'dna': '<path d="M2 15c6.667-6 13.333 0 20-6"/>',
  'hand-heart': '<path d="M11 14h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"/><path d="m7 20 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9"/>',
  'shield-alert': '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/>',
  'message-circle': '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
  'building-2': '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>',
};

function getIcon(name: string): string {
  return icons[name] || icons['message-circle'];
}

const statusColors: Record<string, string> = {
  'completed': 'bg-green-900/40 text-green-400 border-green-700/40',
  'in-progress': 'bg-blue-900/40 text-blue-400 border-blue-700/40',
  'concept': 'bg-yellow-900/40 text-yellow-400 border-yellow-700/40',
  'minimal': 'bg-gray-800/40 text-gray-400 border-gray-700/40',
};
const statusLabels: Record<string, string> = {
  'completed': 'Completado', 'in-progress': 'En progreso', 'concept': 'Concepto', 'minimal': 'Minimal',
};
---
<Layout title="Proyectos">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2 flex items-center gap-3">
      <svg class="w-8 h-8 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
      Proyectos del Blitz
    </h1>
    <p class="text-gray-400">Todos los datos provienen de los archivos MD — editables y dinamicos</p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    {[
      { label: "Proyectos totales", value: totalProjects, iconSvg: '<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>' },
      { label: "Participantes", value: `${totalMembers}+`, iconSvg: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>' },
      { label: "Contratos on-chain", value: deployedContracts, iconSvg: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>' },
      { label: "Mayor avance", value: `${maxPhase}%`, iconSvg: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>' },
    ].map(s => (
      <div class="bg-purple-900/20 border border-purple-800/30 rounded-xl p-4 text-center">
        <div class="flex justify-center mb-2"><svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={s.iconSvg} /></svg></div>
        <div class="text-xl font-bold text-white">{s.value}</div>
        <div class="text-xs text-gray-400 mt-1">{s.label}</div>
      </div>
    ))}
  </div>

  <div class="space-y-4">
    {projects.map(p => (
      <a href={`/reportes/${p.data.slug}`} class={`block rounded-2xl border p-5 transition-all hover:border-purple-500/60 ${p.data.status === 'completed' ? 'bg-purple-900/20 border-purple-600/50 ring-1 ring-purple-500/20' : 'bg-[#0f0f1a] border-purple-900/30'}`}>
        <div class="flex items-start justify-between gap-4 mb-3 flex-wrap">
          <div class="flex items-center gap-3 flex-wrap">
            <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon(p.data.icon)} /></svg>
            <div>
              <h2 class="text-lg font-bold text-white">{p.data.title}</h2>
              <span class="text-xs text-purple-300">{p.data.area}</span>
            </div>
            <span class={`text-xs border rounded-full px-2 py-0.5 ${statusColors[p.data.status]}`}>{statusLabels[p.data.status]}</span>
          </div>
          <div class="text-right">
            {p.data.members > 0 && <div class="text-xs text-gray-400">{p.data.members} miembro{p.data.members !== 1 ? 's' : ''}</div>}
            <div class="text-xs text-gray-500 font-mono">{p.data.messages} msgs</div>
          </div>
        </div>

        {p.data.techStack.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-3">
            {p.data.techStack.map(t => (
              <span class="text-xs bg-purple-900/30 text-purple-300 border border-purple-800/30 rounded px-2 py-0.5">{t}</span>
            ))}
          </div>
        )}

        <div class="flex flex-wrap gap-4 items-start">
          <div class="flex-1 min-w-40">
            <div class="flex justify-between text-xs text-gray-400 mb-1">
              <span>Avance</span>
              <span class="text-white">{p.data.phase}%</span>
            </div>
            <div class="h-2 bg-gray-800 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-purple-600 to-purple-400 rounded-full" style={`width:${Math.min(p.data.phase, 100)}%`}></div>
            </div>
          </div>

          {p.data.contracts.filter(c => c.deployed).length > 0 && (
            <div class="flex-1 min-w-40">
              <div class="text-xs text-gray-400 mb-1">Contratos on-chain</div>
              {p.data.contracts.filter(c => c.deployed).map(c => (
                <div class="text-xs">
                  <span class="text-green-400 font-medium">{c.name}</span>
                  {c.address && <span class="block font-mono text-gray-500 truncate">{c.address.slice(0,22)}...</span>}
                </div>
              ))}
            </div>
          )}

          <div class="flex gap-3">
            {p.data.repo && <a href={p.data.repo} target="_blank" class="text-xs text-purple-400 hover:text-purple-300 hover:underline flex items-center gap-1"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>GitHub</a>}
            {p.data.deployUrl && <a href={p.data.deployUrl} target="_blank" class="text-xs text-green-400 hover:text-green-300 hover:underline flex items-center gap-1"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>Deploy</a>}
          </div>
        </div>

        {p.data.errors.length > 0 && (
          <div class="mt-3 border-t border-gray-800/50 pt-2">
            <div class="text-xs text-gray-500">
              {p.data.errors.length} error{p.data.errors.length > 1 ? 'es' : ''} documentado{p.data.errors.length > 1 ? 's' : ''} — {p.data.errors.filter(e => e.resolved).length} resuelto{p.data.errors.filter(e => e.resolved).length > 1 ? 's' : ''}
            </div>
          </div>
        )}
      </a>
    ))}
  </div>
</Layout>
