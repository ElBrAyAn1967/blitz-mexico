---
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "Reporte completo del Monad Blitz CDMX — Feb 22 2026" } = Astro.props;

const navItems = [
  { href: "/", label: "Reporte", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>` },
  { href: "/proyectos", label: "Proyectos", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>` },
  { href: "/agentes", label: "Agentes", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/></svg>` },
  { href: "/insights", label: "Insights", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>` },
  { href: "/analytics", label: "Analytics", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>` },
];
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Monad Blitz CDMX</title>
  </head>
  <body class="bg-[#0a0a0f] text-gray-100 min-h-screen font-sans">
    <nav class="border-b border-purple-900/40 sticky top-0 z-50 bg-[#0a0a0f]/95 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
          <span class="font-bold text-white group-hover:text-purple-400 transition-colors">Monad Blitz CDMX</span>
          <span class="text-xs text-purple-400 border border-purple-700/50 rounded px-1.5 py-0.5">Feb 22 · 2026</span>
        </a>
        <div class="flex items-center gap-1 text-sm overflow-x-auto">
          {navItems.map(n => (
            <a href={n.href} class="px-3 py-1.5 rounded-lg hover:bg-purple-900/30 hover:text-purple-300 transition-colors whitespace-nowrap flex items-center gap-1.5">
              <Fragment set:html={n.icon} />
              {n.label}
            </a>
          ))}
        </div>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-purple-900/30 mt-16 py-8 text-center text-gray-500 text-sm">
      <p>Generado por <span class="text-purple-400">devrel-banana</span> + <span class="text-purple-400">aibus-dumbleclaw</span></p>
      <p class="mt-1">Monad Blitz CDMX · Sabado 22 Feb 2026 · Datos dinamicos desde MD frontmatter</p>
    </footer>
  </body>
</html>
