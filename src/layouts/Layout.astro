---
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "Reporte completo del Monad Blitz CDMX — Feb 22 2026" } = Astro.props;

const navItems = [
  { href: "/", label: "Reporte", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>` },
  { href: "/proyectos", label: "Proyectos", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>` },
  { href: "/insights", label: "Insights", icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>` },
];
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Monad Blitz CDMX</title>
    <style>
      /* Mobile menu */
      #mobile-menu {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(10, 10, 15, 0.98);
        z-index: 100;
        padding-top: 80px;
      }
      #mobile-menu.open {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }
      #mobile-menu a {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        font-size: 1.25rem;
        color: #e5e5e5;
        border-radius: 0.75rem;
        transition: all 0.2s;
        width: 200px;
      }
      #mobile-menu a:hover {
        background: rgba(147, 51, 234, 0.2);
        color: #c084fc;
      }
      #menu-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.75rem;
        color: #9ca3af;
      }
      /* Hide hamburger on desktop */
      @media (min-width: 640px) {
        #menu-btn { display: none !important; }
      }
      /* Hide nav links on mobile */
      @media (max-width: 639px) {
        .desktop-nav { display: none !important; }
      }
    </style>
  </head>
  <body class="bg-[#0a0a0f] text-gray-100 min-h-screen font-sans">
    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu">
      <button id="menu-close" aria-label="Cerrar menú">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      {navItems.map(n => (
        <a href={n.href}>
          <Fragment set:html={n.icon} />
          {n.label}
        </a>
      ))}
    </div>

    <nav class="border-b border-purple-900/40 sticky top-0 z-50 bg-[#0a0a0f]/95 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group shrink-0">
          <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
          <span class="font-bold text-white text-sm sm:text-base">Monad Blitz</span>
          <span class="hidden sm:inline font-bold text-purple-400">CDMX</span>
          <span class="text-xs text-purple-400 border border-purple-700/50 rounded px-1.5 py-0.5 hidden sm:inline">Feb 22 · 2026</span>
        </a>

        <!-- Desktop Nav -->
        <div class="desktop-nav flex items-center gap-1 text-sm">
          {navItems.map(n => (
            <a href={n.href} class="px-3 py-1.5 rounded-lg hover:bg-purple-900/30 hover:text-purple-300 transition-colors whitespace-nowrap flex items-center gap-1.5">
              <Fragment set:html={n.icon} />
              {n.label}
            </a>
          ))}
        </div>

        <!-- Mobile Hamburger -->
        <button id="menu-btn" class="p-2 rounded-lg hover:bg-purple-900/30 transition-colors" aria-label="Abrir menú">
          <svg class="w-6 h-6 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-6 sm:py-8">
      <slot />
    </main>

    <footer class="border-t border-purple-900/30 mt-12 sm:mt-16 py-6 sm:py-8 text-center text-gray-500 text-xs sm:text-sm px-4">
      <p>Generado por <span class="text-purple-400">devrel-banana</span> + <span class="text-purple-400">aibus-dumbleclaw</span></p>
      <p class="mt-1">Monad Blitz CDMX · Sábado 22 Feb 2026</p>
    </footer>

    <script>
      const menuBtn = document.getElementById('menu-btn');
      const menuClose = document.getElementById('menu-close');
      const mobileMenu = document.getElementById('mobile-menu');
      
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
      
      menuClose?.addEventListener('click', () => {
        mobileMenu?.classList.remove('open');
        document.body.style.overflow = '';
      });
      
      // Close menu when clicking a link
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.remove('open');
          document.body.style.overflow = '';
        });
      });
    </script>
  </body>
</html>
